# Google OAuth 설정
# Google Cloud Console → APIs & Services → Credentials에서 발급
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# 콜백 주소 (배포 시 실제 도메인으로 변경)
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# JWT 시크릿 (기본값: ccx_secret_2025)
JWT_SECRET=ccx_secret_2025

# 세션 시크릿
SESSION_SECRET=ccx_session_secret_2025

# 로그인 성공/실패 후 리다이렉트 경로
AUTH_SUCCESS_REDIRECT=/
AUTH_FAILURE_REDIRECT=/login?error=google_failed

# 서버 포트
PORT=3000
